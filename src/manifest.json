{
  "manifest_version": 2,
  "name": "elodin-plugin",
  "version": "1.0.0",
  "description": "generate some nonsense.",
  "background": {
    "scripts": [ "index.js" ]
  },
  "permissions": [
    "notifications"
  ],
  "commands": {
    "generate-name": {
      "description": "add a name to the clipboard",
      "suggested_key": {
        "default": "Ctrl+E"
      }
    }
  }
}
