{
  "exclude": [ "node_modules" ],
  "compilerOptions": {
    "typeRoots": [
      "node_modules/@types",
      "node_modules/web-ext-types"
    ],
    "outDir": "./dist",
    "lib": ["dom", "es2016"],
    "module": "commonjs",
    "target": "es6",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "resolveJsonModule": true
  }
}
